# FinCA – Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit your .env file to GitHub

# ─── AI Model API Keys ───────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Vector Database ─────────────────────────────────────────────────────────
# ChromaDB (local, no key needed by default)
CHROMA_PERSIST_DIR=./data/chroma_db

# Pinecone (cloud vector DB)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment_here
PINECONE_INDEX_NAME=finca-index

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@localhost:5432/finca_db
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=finca_db

# ─── FastAPI Settings ────────────────────────────────────────────────────────
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# ─── Frontend ────────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000
REACT_APP_APP_NAME=FinCA

# ─── LangChain Settings ──────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=finca

# ─── Model Selection ─────────────────────────────────────────────────────────
PRIMARY_MODEL=gpt-4o
FALLBACK_MODEL=gemini-pro
EMBEDDING_MODEL=text-embedding-3-small

# ─── App Settings ────────────────────────────────────────────────────────────
APP_NAME=FinCA
APP_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO
